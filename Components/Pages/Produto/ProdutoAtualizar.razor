@page "/produtos/{Id:int}/editar"
@rendermode InteractiveServer

@using AppExemplo.Models
@inject ProdutoDAO produtoDao
@inject NavigationManager Navigation

<PageTitle>Produto - Editar</PageTitle>

<header class="topbar" style="display: flex; justify-content: space-between; align-items: center; background-color: #004b93; color: white; padding: 10px 20px;">
    <div class="logo" style="display: flex; align-items: center; gap: 10px;">
        <span style="font-weight: bold; font-size: 1.2rem;">PRODUTOS</span>
    </div>

    <button @onclick="VoltarInicio"
            style="font-size: 24px; background: none; border: none; color: white; cursor: pointer;"
            title="Voltar para início">🏠</button>
</header>

@if (erro != null)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="container mt-4">
    <EditForm Model="_produto" OnSubmit="Salvar">
        <div class="row g-4">

            <div class="col-md-6">
                <label class="form-label fw-semibold">Nome</label>
                <input @bind-value="_produto!.Nome" class="form-control form-control-lg" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Marca</label>
                <input @bind-value="_produto!.Marca" class="form-control form-control-lg" />
            </div>

            <div class="col-md-12">
                <label class="form-label fw-semibold">Descrição</label>
                <textarea @bind="_produto!.Descricao" class="form-control form-control-lg"></textarea>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Quantidade</label>
                <input type="number" @bind-value="_produto!.Quantidade" class="form-control form-control-lg" />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Preço</label>
                <input type="number" step="0.01" @bind-value="_produto!.Preco" class="form-control form-control-lg" />
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <button type="button" class="btn btn-secondary px-4" @onclick="LimparFormulario">
                    Limpar
                </button>
                <button type="submit" class="btn btn-primary px-4">
                    Salvar
                </button>
            </div>

        </div>
    </EditForm>
</div>

@code {

    [Parameter]
    public int Id { get; set; }

    private Produto _produto = new();
    private string? erro;

    protected override void OnInitialized()
    {
        _produto = produtoDao.BuscarPorId(Id);

        if (_produto == null)
        {
            erro = "Produto não encontrado";
            _produto = new Produto();
        }
    }

    private void Salvar()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_produto.Nome))
                throw new Exception("O nome do produto é obrigatório.");

            produtoDao.Atualizar(_produto);
            Navigation.NavigateTo("/produtos");
        }
        catch (Exception ex)
        {
            erro = ex.Message;
        }
    }

    private void LimparFormulario()
    {
        _produto = new Produto();
        erro = null;
    }

    private void VoltarInicio()
    {
        Navigation.NavigateTo("/");
    }
}
