@page "/servicos/{Id:int}/editar"
@rendermode InteractiveServer

@using AppExemplo.Models
@inject ServicoDAO servicoDao
@inject NavigationManager Navigation

<PageTitle>Serviço - Editar</PageTitle>

<header class="topbar" style="display: flex; justify-content: space-between; align-items: center; background-color: #004b93; color: white; padding: 10px 20px;">
    <div class="logo" style="display: flex; align-items: center; gap: 10px;">
        <img src="https://img.icons8.com/color/48/000000/bird--v1.png" />
        <span style="font-weight: bold; font-size: 1.2rem;">GESTÃO DE SERVIÇOS</span>
    </div>

    <button @onclick="VoltarInicio"
            style="font-size: 24px; background: none; border: none; color: white; cursor: pointer;"
            title="Voltar para início">🏠</button>
</header>

@if (erro != null)
{
    <div class="alert alert-danger">@erro</div>
}

<div class="container mt-4">
    <EditForm Model="_servico" OnSubmit="Salvar">
        <div class="row g-4">

            <div class="col-md-6 col-lg-4">
                <label class="form-label fw-semibold">Descrição</label>
                <input @bind-value="_servico.Descricao" type="text" class="form-control form-control-lg" />
            </div>

            <div class="col-md-6 col-lg-3">
                <label class="form-label fw-semibold">Tipo</label>
                <input @bind-value="_servico.Tipo" type="text" class="form-control form-control-lg" />
            </div>

            <div class="col-md-6 col-lg-3">
                <label class="form-label fw-semibold">Valor</label>
                <input @bind-value="_servico.Valor"
       type="number"
       step="0.01"
       class="form-control"
       placeholder="Ex: 90.00" />

            </div>

            <div class="col-md-6 col-lg-1">
                <label class="form-label fw-semibold">Funcionário</label>
                <input @bind-value="_servico.Id_Funcionario" type="number" class="form-control form-control-lg" />
            </div>

            <div class="col-md-6 col-lg-1">
                <label class="form-label fw-semibold">Cliente</label>
                <input @bind-value="_servico.Id_Clientes" type="number" class="form-control form-control-lg" />
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <button type="button" class="btn btn-secondary px-4" @onclick="LimparFormulario">
                    Limpar
                </button>
                <button type="submit" class="btn btn-primary px-4">
                    Salvar
                </button>
            </div>

        </div>
    </EditForm>
</div>

@code {

    private string? erro = null;

    [Parameter]
    public int Id { get; set; }

    private Servico _servico = new();

    protected override void OnInitialized()
    {
        _servico = servicoDao.BuscarPorId(Id);

        if (_servico == null)
        {
            erro = "Serviço não encontrado";
        }
    }

    private void Salvar()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_servico.Descricao))
            {
                throw new Exception("A descrição do serviço é obrigatória.");
            }

            if (string.IsNullOrWhiteSpace(_servico.Valor))
            {
                throw new Exception("O valor do serviço é obrigatório.");
            }

            servicoDao.Atualizar(_servico);
            Navigation.NavigateTo("/servicos");
        }
        catch (Exception ex)
        {
            erro = ex.Message;
        }
    }

    private void LimparFormulario()
    {
        _servico = new Servico();
        erro = null;
    }

    private void VoltarInicio()
    {
        Navigation.NavigateTo("/");
    }
}
