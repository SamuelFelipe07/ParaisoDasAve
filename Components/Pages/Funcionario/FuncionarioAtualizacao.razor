@page "/funcionarios/{Id:int}/editar/"

@using AppExemplo.Models
@inject ServicoDAO servicoDao
@inject NavigationManager Navigation

<h3>Atualizar Serviço</h3>

@if (!string.IsNullOrEmpty(erro))
{
    <div class="alert alert-danger">
        @erro
    </div>
}

@if (servico != null)
{
    <div class="mb-3">
        <label>Descrição</label>
        <input class="form-control" @bind="servico.Descricao" />
    </div>

    <div class="mb-3">
        <label>Tipo</label>
        <input class="form-control" @bind="servico.Tipo" />
    </div>

    <div class="mb-3">
        <label>Valor</label>
        <input type="number" step="0.01" class="form-control" @bind="servico.Valor" />
    </div>

    <div class="mb-3">
        <label>Funcionário</label>
        <input class="form-control" @bind="servico.Id_Funcionario" />
    </div>

    <div class="mb-3">
        <label>Cliente</label>
        <input class="form-control" @bind="servico.Id_Clientes" />
    </div>

    <button class="btn btn-primary" @onclick="Atualizar">
        Salvar
    </button>

    <button class="btn btn-secondary ms-2" @onclick="Voltar">
        Cancelar
    </button>
}
else
{
    <p>Carregando serviço...</p>
}

@code {
    [Parameter]
    public int Id { get; set; }

    Servico? servico;
    string erro = string.Empty;

    protected override void OnInitialized()
    {
        try
        {
            servico = servicoDao.BuscarPorId(Id);

            if (servico == null)
            {
                erro = "Serviço não encontrado.";
            }
        }
        catch (Exception ex)
        {
            erro = "Erro ao carregar serviço: " + ex.Message;
        }
    }

    void Atualizar()
    {
        try
        {
            servicoDao.Atualizar(servico);
            Navigation.NavigateTo("/servico");
        }
        catch (Exception ex)
        {
            erro = "Erro ao atualizar o serviço: " + ex.Message;
        }
    }

    void Voltar()
    {
        Navigation.NavigateTo("/servico");
    }
}
